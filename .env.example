## Local with Docker Compose DB:
# DATABASE_URL="postgresql://postgres:postgres@db:5432/we_want_the_truth"
## Local without Docker (direct local postgres):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/we_want_the_truth"

NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"

NEXT_PUBLIC_APP_URL="http://localhost:3001"

MARKETING_HOSTS="localhost,we-want-the-truth.com,www.we-want-the-truth.com"
SUPER_ADMIN_HOSTS="admin.we-want-the-truth.com"

# JSON map: {"yourtenant.com":"tenant-slug","admin.yourtenant.com":"tenant-slug"}
TENANT_HOST_MAP="{}"

# Stripe (optional if billing disabled)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_ADVANCED_ADMIN=""
STRIPE_PRICE_VIDEO=""
STRIPE_PRICE_COMMENTS=""
STRIPE_PRICE_DOMAIN_SETUP=""

# S3 uploads (optional; upload API returns 501 until configured)
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET=""

# Ciright tenant admin login API
CIRIGHT_LOGIN_URL="https://myciright.com/Ciright/api/commonrestapi/m1342055"
CIRIGHT_SUBSCRIPTION_ID="9329"
CIRIGHT_VERTICAL_ID="18"
CIRIGHT_APP_ID="2967"
# Optional override. Default is "<tenantSlug>.htm"
CIRIGHT_SPHERE_TYPE_URL=""
# Optional override for /super-admin/login. Default is "we-want-the-truth.htm"
CIRIGHT_SUPERADMIN_SPHERE_TYPE_URL="we-want-the-truth.htm"
