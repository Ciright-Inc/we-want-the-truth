generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  TENANT_EDITOR
  PUBLIC_USER
}

enum TenantStatus {
  ACTIVE
  PENDING_SETUP
  SUSPENDED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
}

enum PartyRole {
  PLAINTIFF
  DEFENDANT
  COUNSEL
  OTHER
}

enum CommentStatus {
  PENDING
  APPROVED
  HIDDEN
  REJECTED
}

enum JuryPosition {
  FOR_PLAINTIFF
  FOR_DEFENDANT
  UNDECIDED
}

enum AddOnType {
  ADVANCED_ADMIN
  VIDEO_MANAGEMENT
  COMMENT_MANAGEMENT
}

enum FileVisibility {
  PUBLIC
  PRIVATE
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  emailVerified    DateTime?
  passwordHash     String?
  name             String?
  image            String?
  role             UserRole         @default(PUBLIC_USER)
  tenantId         String?
  tenant           Tenant?          @relation(fields: [tenantId], references: [id])
  disabled         Boolean          @default(false)
  termsAcceptedAt  DateTime?
  accounts         Account[]
  sessions         Session[]
  comments         Comment[]
  juryVotes        JuryVote[]
  videoPlayEvents  VideoPlayEvent[]
  auditLogs        AuditLog[]       @relation("AuditActor")
  abuseReportsFile AbuseReport[]    @relation("Reporter")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([tenantId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Tenant {
  id                   String               @id @default(cuid())
  slug                 String               @unique
  name                 String
  status               TenantStatus         @default(ACTIVE)
  suspended            Boolean              @default(false)
  ownerId              String?
  domains              TenantDomain[]
  users                User[]
  caseMatter           CaseMatter?
  subscriptions        Subscription[]
  auditLogs            AuditLog[]
  pageViews            PageView[]
  domainRegistrations   DomainRegistration[]
  videoAssets          VideoAsset[]
  fileAssets           FileAsset[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
}

model TenantDomain {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  hostname  String   @unique
  isPrimary Boolean  @default(false)
  sslStatus String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model CaseMatter {
  id                       String         @id @default(cuid())
  tenantId                 String         @unique
  tenant                   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title                    String
  caseSummary              String         @db.Text
  heroStatement            String?        @db.Text
  category                 String?
  jurisdiction             String?
  courtOrForum             String?
  matterNumber             String?
  statusLabel              String?
  logoUrl                  String?
  themePreference          String         @default("dark")
  isPublicCase             Boolean        @default(true)
  allowAnonymousBrowsing   Boolean        @default(true)
  publicJuryEnabled        Boolean        @default(true)
  showAggregateVotes       Boolean        @default(true)
  commentModerationDefault Boolean        @default(true)
  plaintiffLabel           String?
  defendantLabel           String?
  counselNotes             String?        @db.Text
  totalViews               Int            @default(0)
  registeredUserCount      Int            @default(0)
  documents                Document[]
  timelineItems            TimelineItem[]
  evidenceItems            EvidenceItem[]
  comments                 Comment[]
  juryVotes                JuryVote[]
  parties                  Party[]
  videoAssets              VideoAsset[]
  deletedAt                DateTime?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
}

model Party {
  id           String     @id @default(cuid())
  caseMatterId String
  caseMatter   CaseMatter @relation(fields: [caseMatterId], references: [id], onDelete: Cascade)
  role         PartyRole
  name         String
  description  String?    @db.Text
  sortOrder    Int        @default(0)
}

model FileAsset {
  id             String     @id @default(cuid())
  tenantId       String
  tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key            String     @unique
  bucket         String
  mimeType       String
  sizeBytes      Int
  originalName   String
  virusScanStatus String    @default("pending")
  documents      Document[]
  createdAt      DateTime   @default(now())

  @@index([tenantId])
}

model Document {
  id           String         @id @default(cuid())
  caseMatterId String
  caseMatter   CaseMatter     @relation(fields: [caseMatterId], references: [id], onDelete: Cascade)
  title        String
  documentDate DateTime?
  filingType   String?
  description  String?        @db.Text
  source       String?
  visibility   FileVisibility @default(PUBLIC)
  fileAssetId  String?
  fileAsset    FileAsset?     @relation(fields: [fileAssetId], references: [id])
  tags         String[]       @default([])
  viewCount    Int            @default(0)
  deletedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([caseMatterId])
}

model VideoAsset {
  id             String         @id @default(cuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  caseMatterId   String?
  caseMatter     CaseMatter?    @relation(fields: [caseMatterId], references: [id], onDelete: SetNull)
  title          String
  fileAssetId    String?
  embedUrl       String?
  thumbnailUrl   String?
  timelineItems  TimelineItem[]
  deletedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([tenantId])
}

model TimelineItem {
  id                  String         @id @default(cuid())
  caseMatterId        String
  caseMatter          CaseMatter     @relation(fields: [caseMatterId], references: [id], onDelete: Cascade)
  eventDate           DateTime
  title               String
  shortSummary        String?        @db.Text
  fullDescription     String         @db.Text
  category            String?
  visibility          FileVisibility @default(PUBLIC)
  featured            Boolean        @default(false)
  relatedDocumentIds  String[]       @default([])
  relatedEvidenceIds  String[]       @default([])
  videoUrl            String?
  videoAssetId        String?
  videoAsset          VideoAsset?    @relation(fields: [videoAssetId], references: [id])
  audioFileUrl        String?
  imageUrls           String[]       @default([])
  deletedAt           DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([caseMatterId])
}

model EvidenceItem {
  id                  String         @id @default(cuid())
  caseMatterId        String
  caseMatter          CaseMatter     @relation(fields: [caseMatterId], references: [id], onDelete: Cascade)
  title               String
  exhibitLabel        String?
  evidenceDate        DateTime?
  description         String?        @db.Text
  evidenceText        String?        @db.Text
  evidenceType        String
  attachmentFileKeys  String[]       @default([])
  relatedTimelineIds  String[]       @default([])
  relatedDocumentIds  String[]       @default([])
  chainOfCustodyNotes String?        @db.Text
  visibility          FileVisibility @default(PUBLIC)
  tags                String[]       @default([])
  deletedAt           DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([caseMatterId])
}

model Comment {
  id                  String        @id @default(cuid())
  caseMatterId        String
  caseMatter          CaseMatter    @relation(fields: [caseMatterId], references: [id], onDelete: Cascade)
  userId              String
  user                User          @relation(fields: [userId], references: [id])
  body                String        @db.Text
  relatedDocumentId   String?
  relatedTimelineId   String?
  relatedEvidenceId   String?
  status              CommentStatus @default(PENDING)
  abuseFlagged        Boolean       @default(false)
  pinned              Boolean       @default(false)
  deletedAt           DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([caseMatterId])
  @@index([userId])
}

model JuryVote {
  id           String       @id @default(cuid())
  caseMatterId String
  caseMatter   CaseMatter   @relation(fields: [caseMatterId], references: [id], onDelete: Cascade)
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  position     JuryPosition
  sessionId    String?
  ipHash       String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([caseMatterId, userId])
  @@index([caseMatterId])
}

model VideoPlayEvent {
  id               String    @id @default(cuid())
  videoId          String
  timelineItemId   String?
  tenantId         String
  userId           String?
  user             User?     @relation(fields: [userId], references: [id])
  anonymousSession String?
  secondsWatched   Int       @default(0)
  completed        Boolean   @default(false)
  createdAt        DateTime  @default(now())

  @@index([tenantId])
  @@index([videoId])
  @@index([timelineItemId])
}

model Subscription {
  id               String               @id @default(cuid())
  tenantId         String
  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stripeCustomerId String?              @unique
  stripeSubId      String?              @unique
  status           SubscriptionStatus   @default(INCOMPLETE)
  currentPeriodEnd DateTime?
  addOns           SubscriptionAddOn[]
  invoices         Invoice[]
  payments         Payment[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([tenantId])
}

model SubscriptionAddOn {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  type           AddOnType
  stripePriceId String?
  active         Boolean      @default(true)

  @@unique([subscriptionId, type])
}

model Invoice {
  id             String       @id @default(cuid())
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  tenantId       String?
  stripeInvoiceId String?     @unique
  amountCents    Int
  currency       String       @default("usd")
  status         String
  pdfUrl         String?
  createdAt      DateTime     @default(now())
}

model Payment {
  id              String        @id @default(cuid())
  subscriptionId  String?
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])
  stripePaymentId String?       @unique
  amountCents     Int
  currency        String        @default("usd")
  status          String
  createdAt       DateTime      @default(now())
}

model DomainRegistration {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  domainName   String
  registrarRef String?
  costCents    Int?
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
}

model PageView {
  id        String   @id @default(cuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  path      String
  sessionId String?
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  userId    String?
  user      User?    @relation("AuditActor", fields: [userId], references: [id])
  action    String
  resource  String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model AbuseReport {
  id          String   @id @default(cuid())
  reporterId  String?
  reporter    User?    @relation("Reporter", fields: [reporterId], references: [id])
  targetType  String
  targetId    String
  tenantId    String?
  reason      String   @db.Text
  status      String   @default("open")
  createdAt   DateTime @default(now())
}

model LegalNotice {
  id          String    @id @default(cuid())
  tenantId    String?
  reference   String?
  body        String    @db.Text
  status      String    @default("queued")
  processedAt DateTime?
  createdAt   DateTime  @default(now())
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}
